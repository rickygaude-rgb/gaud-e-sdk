# GAUD-E API Configuration
# Get your API key from https://platform.gaude.ai/api-keys
VITE_GAUDE_API_KEY=your_api_key_here

# GAUD-E API Endpoint
VITE_GAUDE_API_URL=https://api.gaude.ai/v1

# Google Maps API Key (for terrain selection in GaudeMapSelector)
# Get your key from https://console.cloud.google.com/
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here

# Optional: Development environment configuration
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
